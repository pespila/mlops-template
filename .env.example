# Copy to .env and fill in values. `.env` is gitignored.

# ---------- Platform ----------
PLATFORM_ENV=dev
PLATFORM_SECRET_KEY=change-me-to-a-64-char-random-string
PLATFORM_ADMIN_EMAIL=admin@aipacken.local
PLATFORM_ADMIN_PASSWORD=change-me

# ---------- Postgres ----------
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
DATABASE_URL=postgresql+psycopg://platform:platform@postgres:5432/platform

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Storage (named Docker volume mounted into api/worker/builder) ----------
# Everything the platform produces lives here: datasets, run artifacts,
# SHAP/bias reports, serialized models. No S3, no presigned URLs.
DATA_ROOT=/var/platform-data

# ---------- Builder / Docker ----------
BUILDER_URL=http://builder:8080
TRAINING_DEFAULT_CPU=4
TRAINING_DEFAULT_MEMORY_GB=8
TRAINING_JOB_TIMEOUT_SECONDS=7200

# ---------- Auth ----------
SESSION_COOKIE_NAME=platform_session
SESSION_MAX_AGE_SECONDS=86400

# ---------- Internal token (serving → api ingest path) ----------
INTERNAL_HMAC_TOKEN=change-me-to-a-random-32-char-string

# ---------- Image tags for dynamic container builds ----------
TRAINER_BASE_IMAGE=platform/trainer-base:latest
SERVING_BASE_IMAGE=platform/serving-base:latest
MODELS_NETWORK=models-net

# ---------- Retention ----------
PREDICTION_RETENTION_DAYS=90
ARTIFACT_RETENTION_DAYS=90

# ---------- MLflow tracking (Batch 32+) ----------
# Tracking server URI the api/worker/trainer use to write & read runs.
# Hidden from the SPA — reachable only on platform-net (no Traefik route).
MLFLOW_TRACKING_URI=http://mlflow:5000
# Feature flag: Batches 32-34 ship with MLflow reads OFF by default so
# the existing DB-backed flow keeps serving the frontend. Flip to true
# during Batch 34 cutover.
MLFLOW_BACKEND=false
# Credentials for the MinIO instance that backs MLflow artifact storage.
# Dev placeholders — rotate before exposing the stack beyond localhost.
MINIO_ROOT_USER=platform-minio
MINIO_ROOT_PASSWORD=change-me-to-a-random-24-char
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=platform-minio
AWS_SECRET_ACCESS_KEY=change-me-to-a-random-24-char
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts

# ---------- Frontend ----------
VITE_API_BASE_URL=/api
