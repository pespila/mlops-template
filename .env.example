# Copy to .env and fill in values. `.env` is gitignored.

# ---------- Platform ----------
PLATFORM_ENV=dev
PLATFORM_SECRET_KEY=change-me-to-a-64-char-random-string
PLATFORM_ADMIN_EMAIL=admin@aipacken.local
PLATFORM_ADMIN_PASSWORD=change-me

# ---------- Postgres ----------
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
DATABASE_URL=postgresql+psycopg://platform:platform@postgres:5432/platform

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Storage ----------
# Named Docker volume mounted into api/worker/builder/serving. Carries
# datasets, training run scratch dirs, deployment staging (read-only
# into the serving container), and package tarballs. Heavy MLflow-owned
# artifacts (model.pkl, SHAP/bias reports, metrics.jsonl) live in
# MinIO under the ``mlflow-artifacts`` bucket — see MLFLOW_* below.
DATA_ROOT=/var/platform-data

# ---------- Builder / Docker ----------
BUILDER_URL=http://builder:8080
TRAINING_DEFAULT_CPU=4
TRAINING_DEFAULT_MEMORY_GB=8
TRAINING_JOB_TIMEOUT_SECONDS=7200

# ---------- Auth ----------
SESSION_COOKIE_NAME=platform_session
SESSION_MAX_AGE_SECONDS=86400

# ---------- Internal token (serving → api ingest path) ----------
INTERNAL_HMAC_TOKEN=change-me-to-a-random-32-char-string

# ---------- Image tags for dynamic container builds ----------
TRAINER_BASE_IMAGE=platform/trainer-base:latest
SERVING_BASE_IMAGE=platform/serving-base:latest
MODELS_NETWORK=models-net

# ---------- Retention ----------
PREDICTION_RETENTION_DAYS=90

# ---------- MinIO ----------
# S3-compatible object store that MLflow writes artifacts into. The api
# and trainer never speak S3 directly — MLflow proxies all artifact
# traffic (``--default-artifact-root mlflow-artifacts:/``), so only the
# MLflow server needs credentials.
MINIO_ROOT_USER=platform
MINIO_ROOT_PASSWORD=platform-minio
S3_BUCKET_MLFLOW=mlflow-artifacts

# ---------- MLflow ----------
# Tracking server URI the api/worker/trainer use to write & read runs.
# Hidden from the SPA — reachable only on platform-net (no Traefik route).
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
# Feature flag retained only so the api can fail-closed at startup when
# MLflow is unreachable. True in every supported configuration.
MLFLOW_BACKEND=true

# ---------- Postgres (continued) ----------
POSTGRES_MLFLOW_DB=mlflow

# ---------- boto3 credentials (used by MLflow to read/write MinIO) ----------
# Must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above. boto3 reads
# these two env vars by name; no code change required.
AWS_ACCESS_KEY_ID=platform
AWS_SECRET_ACCESS_KEY=platform-minio

# ---------- Frontend ----------
VITE_API_BASE_URL=/api
