# Copy to .env and fill in values. `.env` is gitignored.

# ---------- Platform ----------
PLATFORM_ENV=dev
PLATFORM_SECRET_KEY=change-me-to-a-64-char-random-string
PLATFORM_ADMIN_EMAIL=admin@local
PLATFORM_ADMIN_PASSWORD=change-me

# ---------- Postgres ----------
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform
POSTGRES_MLFLOW_DB=mlflow
DATABASE_URL=postgresql+psycopg://platform:platform@postgres:5432/platform

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- MinIO / S3 ----------
MINIO_ROOT_USER=platform
MINIO_ROOT_PASSWORD=platform-minio
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_DATASETS=datasets
S3_BUCKET_ARTIFACTS=artifacts
S3_BUCKET_MLFLOW=mlflow-artifacts
S3_BUCKET_REPORTS=reports
S3_BUCKET_PREDICTIONS=predictions

# ---------- MLflow ----------
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ---------- Builder / Docker ----------
BUILDER_URL=http://builder:8080
TRAINING_DEFAULT_CPU=4
TRAINING_DEFAULT_MEMORY_GB=8
TRAINING_JOB_TIMEOUT_SECONDS=7200

# ---------- Auth ----------
SESSION_COOKIE_NAME=platform_session
SESSION_MAX_AGE_SECONDS=86400

# ---------- Internal token (serving → api ingest path) ----------
INTERNAL_HMAC_TOKEN=change-me-to-a-random-32-char-string

# ---------- Image tags for dynamic container builds ----------
TRAINER_BASE_IMAGE=platform/trainer-base:latest
SERVING_BASE_IMAGE=platform/serving-base:latest
MODELS_NETWORK=models-net

# ---------- Retention ----------
PREDICTION_RETENTION_DAYS=90
ARTIFACT_RETENTION_DAYS=90

# ---------- Frontend ----------
VITE_API_BASE_URL=/api
